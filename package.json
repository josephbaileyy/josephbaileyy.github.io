{
  "name": "josephbaileyy.github.io",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run generate:content",
    "dev": "vite",
    "generate:about": "node scripts/generate-about.mjs",
    "generate:notes": "node scripts/generate-notes.mjs",
    "generate:content": "npm run generate:notes && npm run generate:about",
    "fetch:live": "node scripts/fetch-live-data.mjs",
    "build": "npm run generate:content && tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:coverage": "vitest run --exclude 'tests/e2e/**' --coverage",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.19.21",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.3.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cesium": "^1.142.0",
    "postprocessing": "^6.39.1",
    "three": "^0.184.0"
  }
}
